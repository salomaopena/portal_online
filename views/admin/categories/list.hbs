<!--menu navbar-->
{{> navbar }}

<!--main content -->
<div class="content mt-5" id="content">
    <div class="mb-3">
        <span class="content-title">
            {{>page_title}}
        </span>
    </div>
    <hr>

    <div class="mb-3">
        <a href="/admin/categories/new" class="btn btn-primary mb-3">
            <i class="fa-solid fa-plus me-2"></i> Adicionar Categoria
        </a>
    </div>

    <div class="col-xxl col-12">

        <div class="container-fluid mt-4 py-4">

            {{#if categories.length}}
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Categoria</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each categories}}
                    <tr id="category-{{this.id}}">
                        <td>
                            <h5>{{this.id}}</h5>
                        </td>
                        <td>
                            <a href="#" class="text-decoration-none">
                                <h5>{{this.name}}</h5>
                            </a>
                        </td>
                        <td class="text-end align-items-center">

                            <form method="POST" action="/admin/categories/edit/{{this.id}}" style="display: inline;">
                                <button type="submit" class="btn btn-outline-secondary btn-md px-3 m-1"> <i
                                        class="fa-regular fa-pen-to-square me-2"></i>
                                </button>
                            </form>

                            <button onclick="deleteCategory({{this.id}})"
                                class="btn btn-outline-danger btn-md px-3 m-1">
                                <i class="fa-solid fa-trash-can me-2"></i>
                            </button>
                            
                            <a href="#" class="btn btn-outline-warning btn-md px-3 m-1">
                                <i class="fa-solid fa-newspaper me-2"></i>
                            </a>

                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
            {{else}}
            <div class="mb-3 alert alert-danger" role="alert">
                <h4 class="text-muted">{{message}} Clique <a href="/admin/categories/new"
                        class="link-none-decoration">aqui</a>
                    para adicionar</h4>
            </div>
            {{/if}}
        </div>

    </div>
</div>





<script>


    function deleteCategory(id) {
        Swal.fire({
            title: 'Você tem certeza?',
            text: "Você não poderá reverter isso!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#3085d6',
            cancelButtonColor: '#d33',
            confirmButtonText: 'Sim, excluir!'
        }).then((result) => {
            if (result.isConfirmed) {
                // Redireciona para a rota de exclusão
                window.location.href = `/admin/categories/delete/${id}`;
            }
        })
    }

</script>


{{! Se houver um sucesso, exibe uma mensagem de sucesso }}
{{#if success}}
<script>
    document.addEventListener('DOMContentLoaded', function () {
        Swal.fire({
            icon: 'success',
            title: 'Sucesso!',
            text: '{{success}}',
            timer: 2000,
            showConfirmButton: false
        }).then(() => {
            window.location.href = "/admin/categories";
        });
    });
</script>
{{/if}}

{{! Se houver um erro, exibe uma mensagem de erro }}

{{#if error}}
<script>
    document.addEventListener('DOMContentLoaded', function () {
        Swal.fire({
            icon: 'error',
            title: 'Erro!',
            text: '{{error}}',
            timer: 2000,
            showConfirmButton: false
        });
    });
</script>
{{/if}}
